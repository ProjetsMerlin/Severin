{
    "config": {
        "siteName": "Severin",
        "siteUrl": "http://localhost/projets/lintermediaire/en%20cours/Severina/",
        "author": "Merlin",
        "lang": "fr-BE",
        "charset": "UTF-8",
        "description": "Site exemple basé sur des composants PHP",
        "favicon": "assets/images/favicon.ico",
        "defaultPage": "bienvenue",
        "Menu" : {
            "class": "menu-default",
            
            "logo": {
                "image": "assets/images/favicon.ico",
                "alt": "Logo",
                "link": "bienvenue"
            },
            
            "links": [
                {
                    "label": "Bienvenue",
                    "url": "bienvenue"
                },
                {
                    "label": "À propos",
                    "url": "a-propos"
                },
                {
                    "label": "Services",
                    "url": "services"
                },
                {
                    "label": "Contact",
                    "url": "contact"
                }
            ]
        },
        "Footer": {
            "class": "footer-default",
            "text": "© 2026 Severin — Tous droits réservés.",
            "socials": [
                {
                    "label": "Facebook",
                    "url": "https://facebook.com",
                    "icon": "assets/images/facebook.svg"
                },
                {
                    "label": "Instagram",
                    "url": "https://instagram.com",
                    "icon": "assets/images/instagram.svg"
                },
                {
                    "label": "LinkedIn",
                    "url": "https://linkedin.com",
                    "icon": "assets/images/linkedin.svg"
                },
                {
                    "label": "GitHub",
                    "url": "https://github.com",
                    "icon": "assets/images/github.svg"
                }
            ]
        }
    },
    "routes": {
        "404": {
            "seo": {
                "title": "Page non trouvée",
                "description": "La page que vous recherchez n'existe pas."
            },
            "components": [
                {
                    "component": "Error404",
                    "data": {
                        "class": "error404-default",
                        "code": "404",
                        "title": "Page introuvable",
                        "text": "La page que vous recherchez semble inexistante ou a été déplacée.",
                        "button": {
                            "label": "Retour à l'accueil",
                            "link": "/bienvenue"
                        }
                    }
                }
            ]
        },
        "bienvenue": {
            "seo": {
                "title": "Bienvenue",
                "description": "Présentation de Séverin"
            },
            "components": [
                {
                    "component": "Hero",
                    "data": {
                        "class": "hero-default",
                        "image": "assets/images/hero-home.jpg",
                        "subtitle": "Architecture modulaire et éditable",
                        "title": "<b>Severin</b> <span>le template qui vous convient</span>",
                        "text": "Ce contenu provient du JSON éditable via l'admin du site : /admin.<br>Modifiez-le à votre guise !",
                        "button": {
                            "label": "Découvrir",
                            "link": "admin/index.php"
                        }
                    }
                },
                {
                    "component": "Hero",
                    "data": {
                        "class": "hero-default inverted",
                        "image": "assets/images/hero.jpg",
                        "subtitle": "Léger",
                        "title": "Projet ultra léger",
                        "text": "Ce contenu est side ridé côté PHP.",
                        "button": {
                            "label": "Découvrir",
                            "link": "a-propos"
                        }
                    }
                }
            ]
        },
        "a-propos": {
            "seo": {
                "title": "À propos",
                "description": "Page de présentation"
            },
            "components": [
                {
                    "component": "Hero",
                    "data": {
                        "class": "hero-about",
                        "image": "assets/images/hero-about.jpg",
                        "subtitle": "Qui sommes-nous ?",
                        "title": "À propos du projet",
                        "text": "Une architecture simple et scalable.",
                        "button": {
                            "label": "Retour",
                            "link": "bienvenue"
                        }
                    }
                },
                {
                    "component": "Hero",
                    "data": {
                        "class": "hero-about inverted",
                        "image": "assets/images/hero.jpg",
                        "subtitle": "Qui sommes-nous",
                        "title": "À propos du projet",
                        "text": "Une architecture simple et scalable.",
                        "button": {
                            "label": "Retour",
                            "link": "bienvenue"
                        }
                    }
                }
            ]
        }
    }
}